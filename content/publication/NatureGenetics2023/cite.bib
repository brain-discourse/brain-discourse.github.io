@article{Miller2023,
abstract = {Somatic mosaicism is a known cause of neurological disorders, including developmental brain malformations and epilepsy. Brain mosaicism is traditionally attributed to post-zygotic genetic alterations arising in fetal development. Here we describe post-zygotic rescue of meiotic errors as an alternate origin of brain mosaicism in patients with focal epilepsy who have mosaic chromosome 1q copy number gains. Genomic analysis showed evidence of an extra parentally derived chromosome 1q allele in the resected brain tissue from five of six patients. This copy number gain is observed only in patient brain tissue, but not in blood or buccal cells, and is strongly enriched in astrocytes. Astrocytes carrying chromosome 1q gains exhibit distinct gene expression signatures and hyaline inclusions, supporting a novel genetic association for astrocytic inclusions in epilepsy.},
author = {Miller, Katherine E and Rivaldi, Adithe C and Shinagawa, Noriyuki and Sran, Sahib and Navarro, Jason B and Westfall, Jesse J and Miller, Anthony R and Roberts, Ryan D and Akkari, Yassmine and Supinger, Rachel and Hester, Mark E and Marhabaie, Mohammad and Gade, Meethila and Lu, Jinfeng and Rodziyevska, Olga and Bhattacharjee, Meenakshi B and {Von Allmen}, Gretchen K and Yang, Edward and Lidov, Hart G W and Harini, Chellamani and Shah, Manish N and Leonard, Jeffrey and Pindrik, Jonathan and Shaikhouni, Ammar and Goldman, James E and Pierson, Christopher R and Thomas, Diana L and Boué, Daniel R and Ostendorf, Adam P and Mardis, Elaine R and Poduri, Annapurna and Koboldt, Daniel C and Heinzen, Erin L and Bedrosian, Tracy A},
doi = {10.1038/s41588-023-01547-z},
issn = {1546-1718},
journal = {Nature Genetics},
month = {oct},
number = {11},
pages = {1920--1928},
title = {{Post-zygotic rescue of meiotic errors causes brain mosaicism and focal epilepsy}},
url = {https://doi.org/10.1038/s41588-023-01547-z},
volume = {55},
year = {2023}
}
